# API URL - 백엔드 서버 주소
NEXT_PUBLIC_API_URL=http://localhost:8003
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth mode
NEXT_PUBLIC_AUTH_MODE=dual

# 공개 사이트/사업자 표시 정보 (클라이언트에 노출되는 값만 입력)
NEXT_PUBLIC_APP_NAME=My Saju
NEXT_PUBLIC_COMPANY_NAME=Open Source Maintainer
NEXT_PUBLIC_REPRESENTATIVE_NAME=Your Name
NEXT_PUBLIC_BUSINESS_NUMBER=000-00-00000
NEXT_PUBLIC_MAIL_ORDER_NUMBER=제0000-지역-0000호
NEXT_PUBLIC_BUSINESS_ADDRESS=Your business address
NEXT_PUBLIC_CONTACT_EMAIL=support@example.com
NEXT_PUBLIC_CONTACT_PHONE=000-0000-0000

# 선택: 같은 origin API proxy를 특정 도메인에서만 활성화하고 싶을 때 설정
NEXT_PUBLIC_API_PROXY_SITE_HOST_SUFFIX=

# 선택: Web Push / TossPayments 공개 클라이언트 키
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=
